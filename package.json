{
  "name": "tree-sitter-fsm",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the TextX FSM DSL (coord-dsl)",
  "main": "bindings/node",
  "scripts": {
    "build": "tree-sitter generate",
    "test": "tree-sitter test"
